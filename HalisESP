--================================================
--================ ESP SYSTEM ====================
--================================================

local ESP_ENABLED = true
local toggleDebounce = false
local ESPCache = {}
local timeAccumulator = 0

local function setESPEnabled(state)
    ESP_ENABLED = state
    for _, data in pairs(ESPCache) do
        if data.highlight then
            data.highlight.Enabled = ESP_ENABLED
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == TOGGLE_KEY and not toggleDebounce then
        toggleDebounce = true
        setESPEnabled(not ESP_ENABLED)
        task.wait(0.2)
        toggleDebounce = false
    end
end)

--================================================
--================ HITBOX ========================
--================================================

local function applyHitbox(character)
    if not HITBOX_ENABLED then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    pcall(function()
        hrp.Size = HITBOX_SIZE
        hrp.Transparency = HITBOX_TRANSPARENCY
        hrp.CanCollide = false
    end)
end

--================================================
--================ CREATE ESP ====================
--================================================

local function createESP(player)
    if player == LocalPlayer then return end
    if ESPCache[player] then return end

    local data = {}
    ESPCache[player] = data

    local function apply(character)
        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        -- 🔥 apply hitbox
        applyHitbox(character)

        local highlight = Instance.new("Highlight")
        highlight.FillColor = HIGHLIGHT_COLOR
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.FillTransparency = 0.5
        highlight.Adornee = character
        highlight.Enabled = ESP_ENABLED
        highlight.Parent = character

        data.highlight = highlight
        data.hrp = hrp
    end

    if player.Character then
        apply(player.Character)
    end

    player.CharacterAdded:Connect(apply)
end

local function removeESP(player)
    local data = ESPCache[player]
    if not data then return end
    if data.highlight then
        data.highlight:Destroy()
    end
    ESPCache[player] = nil
end

for _, plr in ipairs(Players:GetPlayers()) do
    createESP(plr)
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

-- distance loop
RunService.RenderStepped:Connect(function(dt)
    timeAccumulator += dt
    if timeAccumulator < UPDATE_RATE then return end
    timeAccumulator = 0

    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    for _, data in pairs(ESPCache) do
        local hrp = data.hrp
        local highlight = data.highlight

        if hrp and hrp.Parent and highlight then
            local dist = (hrp.Position - myHRP.Position).Magnitude
            highlight.Enabled = ESP_ENABLED and dist <= MAX_DISTANCE
        end
    end
end)

end)
