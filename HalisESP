--================ ESP SYSTEM ================
local highlights = {}

local function createESP(player)
    if player == LocalPlayer then return end

    local function onCharacter(char)
        if highlights[player] then
            highlights[player]:Destroy()
            highlights[player] = nil
        end

        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local highlight = Instance.new("Highlight")
        highlight.Name = "HALIS_ESP"
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(255, 80, 80)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Enabled = ESP_ENABLED
        highlight.Parent = char

        highlights[player] = highlight
    end

    if player.Character then
        task.spawn(onCharacter, player.Character)
    end

    player.CharacterAdded:Connect(onCharacter)
end

-- Load existing players
for _,player in ipairs(Players:GetPlayers()) do
    createESP(player)
end

-- New players
Players.PlayerAdded:Connect(createESP)

--================ HITBOX EXPAND (VISIBLE ONLY) ================

local HITBOX_SIZE = Vector3.new(6,6,6) -- chỉnh to nhỏ tại đây
local HITBOX_COLOR = Color3.fromRGB(0, 255, 120)
local HITBOX_TRANSPARENCY = 0.6

local camera = Workspace.CurrentCamera
local hitboxFolder = Instance.new("Folder")
hitboxFolder.Name = "HalisHitbox"
hitboxFolder.Parent = game.CoreGui

local hitboxCache = {}

local function isVisible(part)
	if not part then return false end

	local origin = camera.CFrame.Position
	local direction = (part.Position - origin)

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = {LocalPlayer.Character}

	local result = Workspace:Raycast(origin, direction, params)

	if result and result.Instance then
		return result.Instance:IsDescendantOf(part.Parent)
	end

	return true
end

local function createHitbox(player)
	if player == LocalPlayer then return end
	if hitboxCache[player] then return end

	local function apply(char)
		local hrp = char:WaitForChild("HumanoidRootPart", 5)
		if not hrp then return end

		if hitboxCache[player] then
			hitboxCache[player]:Destroy()
		end

		local box = Instance.new("BoxHandleAdornment")
		box.Name = "HALIS_HITBOX"
		box.Adornee = hrp
		box.AlwaysOnTop = false -- ❗ không xuyên tường
		box.ZIndex = 0
		box.Size = HITBOX_SIZE
		box.Color3 = HITBOX_COLOR
		box.Transparency = HITBOX_TRANSPARENCY
		box.Parent = hitboxFolder

		hitboxCache[player] = box
	end

	if player.Character then
		task.spawn(apply, player.Character)
	end

	player.CharacterAdded:Connect(apply)
end

-- load players
for _,plr in ipairs(Players:GetPlayers()) do
	createHitbox(plr)
end

Players.PlayerAdded:Connect(createHitbox)
Players.PlayerRemoving:Connect(function(plr)
	if hitboxCache[plr] then
		hitboxCache[plr]:Destroy()
		hitboxCache[plr] = nil
	end
end)

-- update visibility (không nhìn xuyên tường)
RunService.RenderStepped:Connect(function()
	for player, box in pairs(hitboxCache) do
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			box.Visible = isVisible(char.HumanoidRootPart)
		end
	end
end)
