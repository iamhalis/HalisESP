--================================================
--================ SETTINGS ======================
--================================================

local HIGHLIGHT_COLOR = Color3.fromRGB(255,80,80)
local MAX_DISTANCE = 3000
local UPDATE_RATE = 0.2
local TOGGLE_KEY = Enum.KeyCode.G

-- 🔥 HITBOX SETTINGS
local HITBOX_ENABLED = true
local HITBOX_SIZE = Vector3.new(6,6,6) -- chỉnh to nhỏ ở đây
local HITBOX_TRANSPARENCY = 0.6

--================================================
--================ FPS BOOST =====================
--================================================

local function FPSBoost()
    local terrain = Workspace:FindFirstChildOfClass("Terrain")

    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.FogStart = 9e9
        Lighting.Brightness = 1
        Lighting.ClockTime = 14
        Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
    end)

    local function removeSkyStuff(obj)
        if obj:IsA("Sky")
        or obj:IsA("Atmosphere")
        or obj:IsA("Clouds")
        or obj:IsA("BloomEffect")
        or obj:IsA("BlurEffect")
        or obj:IsA("SunRaysEffect")
        or obj:IsA("ColorCorrectionEffect")
        or obj:IsA("DepthOfFieldEffect") then
            obj:Destroy()
        end
    end

    for _,v in ipairs(Lighting:GetChildren()) do
        removeSkyStuff(v)
    end

    Lighting.ChildAdded:Connect(function(v)
        task.defer(removeSkyStuff, v)
    end)

    if terrain then
        pcall(function()
            terrain.Decoration = false
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 1
        end)
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.Plastic
            obj.Reflectance = 0
        elseif obj:IsA("ParticleEmitter")
        or obj:IsA("Trail")
        or obj:IsA("Fire")
        or obj:IsA("Smoke")
        or obj:IsA("Sparkles") then
            obj.Enabled = false
        end
    end

    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
end

FPSBoost()

