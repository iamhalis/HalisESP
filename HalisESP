pcall(function()

--================ SERVICES ================
repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

--================ SETTINGS ================
local ESP_ENABLED = true

--================ NOTIFICATION ================
pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "Script by @iamhalis",
        Text = "ESP & FPS Boost Activated",
        Duration = 5
    })
end)

--================ FPS BOOST ULTRA ================
task.spawn(function()

    -- Render settings
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- Lighting tối giản
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 1e10
        Lighting.FogStart = 1e10
        Lighting.Brightness = 1
        Lighting.ClockTime = 12
        Lighting.OutdoorAmbient = Color3.new(1,1,1)
    end)

    -- ❌ XÓA SKY
    pcall(function()
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky then
            sky:Destroy()
        end
    end)

    -- ❌ XÓA CLOUDS (mây mới)
    pcall(function()
        local clouds = Workspace:FindFirstChildOfClass("Clouds")
        if clouds then
            clouds:Destroy()
        end
    end)

    -- ❌ TERRAIN tối giản
    pcall(function()
        if Workspace:FindFirstChildOfClass("Terrain") then
            Workspace.Terrain.WaterWaveSize = 0
            Workspace.Terrain.WaterWaveSpeed = 0
            Workspace.Terrain.WaterReflectance = 0
            Workspace.Terrain.WaterTransparency = 1
        end
    end)

    -- ❌ XÓA EFFECT NẶNG
    for _,v in ipairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter")
            or v:IsA("Trail")
            or v:IsA("Beam")
            or v:IsA("Explosion")
            or v:IsA("Fire")
            or v:IsA("Smoke")
            or v:IsA("Sparkles") then
                v:Destroy()
            end
        end)
    end

    -- ❌ Material xuống Plastic
    for _,v in ipairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
            end
        end)
    end

end)

--================ ESP SYSTEM ================
local highlights = {}

local function createESP(player)
    if player == LocalPlayer then return end

    local function onCharacter(char)
        if highlights[player] then
            highlights[player]:Destroy()
            highlights[player] = nil
        end

        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local highlight = Instance.new("Highlight")
        highlight.Name = "HALIS_ESP"
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(255, 80, 80)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Enabled = ESP_ENABLED
        highlight.Parent = char

        highlights[player] = highlight
    end

    if player.Character then
        task.spawn(onCharacter, player.Character)
    end

    player.CharacterAdded:Connect(onCharacter)
end

-- Load existing players
for _,player in ipairs(Players:GetPlayers()) do
    createESP(player)
end

-- New players
Players.PlayerAdded:Connect(createESP)

--================ TOGGLE KEY (G) ================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.G then
        ESP_ENABLED = not ESP_ENABLED

        for _,h in pairs(highlights) do
            if h then
                h.Enabled = ESP_ENABLED
            end
        end

        StarterGui:SetCore("SendNotification", {
            Title = "ESP Toggle",
            Text = ESP_ENABLED and "ESP ON" or "ESP OFF",
            Duration = 3
        })
    end
end)

end)
