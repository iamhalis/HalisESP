pcall(function()
	repeat task.wait() until game:IsLoaded()

	--// SERVICES
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UserInputService = game:GetService("UserInputService")
	local TweenService = game:GetService("TweenService")
	local Lighting = game:GetService("Lighting")
	local Workspace = game:GetService("Workspace")

	local LocalPlayer = Players.LocalPlayer

	--// WAIT PLAYER READY
	repeat task.wait() until LocalPlayer
	repeat task.wait() until LocalPlayer.Character
	repeat task.wait() until LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

	--// ================= FPS BOOST =================
	local function FPSBoost()
		-- lighting basic
		pcall(function()
			Lighting.GlobalShadows = false
			Lighting.FogEnd = 9e9
			Lighting.Brightness = 1
			Lighting.ClockTime = 14
			Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
		end)

		-- REMOVE SKY 🔥
		pcall(function()
			for _, v in ipairs(Lighting:GetChildren()) do
				if v:IsA("Sky") then
					v:Destroy()
				end
			end
			Lighting.SkyboxBk = ""
			Lighting.SkyboxDn = ""
			Lighting.SkyboxFt = ""
			Lighting.SkyboxLf = ""
			Lighting.SkyboxRt = ""
			Lighting.SkyboxUp = ""
		end)

		-- remove heavy effects
		for _, v in pairs(Lighting:GetChildren()) do
			if v:IsA("BloomEffect")
			or v:IsA("BlurEffect")
			or v:IsA("SunRaysEffect")
			or v:IsA("ColorCorrectionEffect")
			or v:IsA("DepthOfFieldEffect") then
				v.Enabled = false
			end
		end

		-- terrain optimization
		pcall(function()
			local terrain = Workspace:FindFirstChildOfClass("Terrain")
			if terrain then
				terrain.WaterWaveSize = 0
				terrain.WaterWaveSpeed = 0
				terrain.WaterReflectance = 0
				terrain.WaterTransparency = 1
			end
		end)

		-- simplify materials
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("BasePart") then
				obj.Material = Enum.Material.Plastic
				obj.Reflectance = 0
			elseif obj:IsA("Decal") or obj:IsA("Texture") then
				obj.Transparency = 0.5
			end
		end

		-- quality level lowest
		pcall(function()
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
		end)
	end

	FPSBoost()

	--// ===== NOTIFICATION =====
	local function showNotification()
		local gui = Instance.new("ScreenGui")
		gui.Name = "HalisNotify"
		gui.ResetOnSpawn = false
		gui.Parent = game.CoreGui

		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(0, 260, 0, 60)
		frame.Position = UDim2.new(0.5, -130, 0.1, 0)
		frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		frame.BackgroundTransparency = 0.35
		frame.BorderSizePixel = 0
		frame.Parent = gui

		local corner = Instance.new("UICorner", frame)
		corner.CornerRadius = UDim.new(0, 12)

		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1, 0, 1, 0)
		text.BackgroundTransparency = 1
		text.Text = "Script by @iamhalis"
		text.TextColor3 = Color3.fromRGB(255, 255, 255)
		text.TextScaled = true
		text.Font = Enum.Font.GothamBold
		text.Parent = frame

		frame.BackgroundTransparency = 1
		text.TextTransparency = 1

		TweenService:Create(frame, TweenInfo.new(0.35), {
			BackgroundTransparency = 0.35
		}):Play()

		TweenService:Create(text, TweenInfo.new(0.35), {
			TextTransparency = 0
		}):Play()

		task.delay(3, function()
			TweenService:Create(frame, TweenInfo.new(0.35), {
				BackgroundTransparency = 1
			}):Play()

			TweenService:Create(text, TweenInfo.new(0.35), {
				TextTransparency = 1
			}):Play()

			task.wait(0.4)
			gui:Destroy()
		end)
	end

	showNotification()

	--// ===== SETTINGS =====
	local HIGHLIGHT_COLOR = Color3.fromRGB(255, 80, 80)
	local MAX_DISTANCE = 3000
	local UPDATE_RATE = 0.2
	local TOGGLE_KEY = Enum.KeyCode.G

	--// ===== STATE =====
	local ESP_ENABLED = true
	local toggleDebounce = false

	--// STORAGE
	local ESPContainer = Instance.new("Folder")
	ESPContainer.Name = "ESPContainer"
	ESPContainer.Parent = game.CoreGui

	--// CACHE
	local ESPCache = {}
	local timeAccumulator = 0

	--// TOGGLE
	local function setESPEnabled(state)
		ESP_ENABLED = state
		for _, data in pairs(ESPCache) do
			if data.highlight then
				data.highlight.Enabled = ESP_ENABLED
			end
		end
	end

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == TOGGLE_KEY and not toggleDebounce then
			toggleDebounce = true
			setESPEnabled(not ESP_ENABLED)
			task.wait(0.2)
			toggleDebounce = false
		end
	end)

	--// CREATE ESP
	local function createESP(player)
		if player == LocalPlayer then return end
		if ESPCache[player] then return end

		local data = {}
		ESPCache[player] = data

		local function apply(character)
			local hrp = character:WaitForChild("HumanoidRootPart", 5)
			if not hrp then return end

			local holder = Instance.new("Folder")
			holder.Name = player.Name
			holder.Parent = ESPContainer
			data.holder = holder
			data.hrp = hrp

			local highlight = Instance.new("Highlight")
			highlight.FillColor = HIGHLIGHT_COLOR
			highlight.OutlineColor = Color3.new(1,1,1)
			highlight.FillTransparency = 0.5
			highlight.Adornee = character
			highlight.Enabled = ESP_ENABLED
			highlight.Parent = holder
			data.highlight = highlight
		end

		if player.Character then
			apply(player.Character)
		end

		player.CharacterAdded:Connect(function(char)
			if data.holder then
				data.holder:Destroy()
			end
			apply(char)
		end)
	end

	local function removeESP(player)
		local data = ESPCache[player]
		if not data then return end
		if data.holder then
			data.holder:Destroy()
		end
		ESPCache[player] = nil
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		createESP(plr)
	end

	Players.PlayerAdded:Connect(createESP)
	Players.PlayerRemoving:Connect(removeESP)

	RunService.RenderStepped:Connect(function(dt)
		timeAccumulator += dt
		if timeAccumulator < UPDATE_RATE then return end
		timeAccumulator = 0

		local myChar = LocalPlayer.Character
		if not myChar then return end
		local myHRP = myChar:FindFirstChild("HumanoidRootPart")
		if not myHRP then return end

		for _, data in pairs(ESPCache) do
			local hrp = data.hrp
			local highlight = data.highlight

			if hrp and hrp.Parent and highlight then
				local dist = (hrp.Position - myHRP.Position).Magnitude
				highlight.Enabled = ESP_ENABLED and dist <= MAX_DISTANCE
			end
		end
	end)

