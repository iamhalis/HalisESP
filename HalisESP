--// =========================================
--// ESP + FPS BOOST + REMOVE GRASS FULL
--// Script by @iamhalis
--// Toggle ESP: G
--// =========================================

pcall(function()

repeat task.wait() until game:IsLoaded()

--// SERVICES
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local Terrain = workspace:FindFirstChildOfClass("Terrain")

local LocalPlayer = Players.LocalPlayer

--// SETTINGS
local ESP_ENABLED = true
local HIGHLIGHT_COLOR = Color3.fromRGB(255,80,80)

--================ NOTIFICATION =================
pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "Script by @iamhalis",
        Text = "ESP & FPS Boost Activated | Toggle = G",
        Duration = 5
    })
end)

--================ REMOVE SKY / CLOUD / FOG =================
local function nukeSky()
    for _,v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Sky")
        or v:IsA("Atmosphere")
        or v:IsA("Clouds")
        or v:IsA("BloomEffect")
        or v:IsA("SunRaysEffect")
        or v:IsA("ColorCorrectionEffect") then
            v:Destroy()
        end
    end

    Lighting.FogEnd = 1e10
    Lighting.FogStart = 1e10
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2

    -- remove grass decoration (IMPORTANT)
    if Terrain then
        pcall(function()
            Terrain.Decoration = false
            Terrain.WaterWaveSize = 0
            Terrain.WaterWaveSpeed = 0
            Terrain.WaterReflectance = 0
            Terrain.WaterTransparency = 1
        end)
    end
end

nukeSky()

Lighting.ChildAdded:Connect(function(child)
    if child:IsA("Sky")
    or child:IsA("Atmosphere")
    or child:IsA("Clouds")
    or child:IsA("BloomEffect")
    or child:IsA("SunRaysEffect")
    or child:IsA("ColorCorrectionEffect") then
        task.wait()
        child:Destroy()
    end
end)

--================ EXTRA FPS BOOST =================
pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end)

for _,v in ipairs(workspace:GetDescendants()) do
    if v:IsA("ParticleEmitter")
    or v:IsA("Trail")
    or v:IsA("Smoke")
    or v:IsA("Fire")
    or v:IsA("Sparkles") then
        v.Enabled = false
    end
end

--================ ESP SYSTEM =================
local highlights = {}

local function createESP(player)
    if player == LocalPlayer then return end

    local function onCharacter(char)
        if highlights[player] then
            highlights[player]:Destroy()
        end

        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local highlight = Instance.new("Highlight")
        highlight.Name = "HALIS_ESP"
        highlight.Adornee = char
        highlight.FillColor = HIGHLIGHT_COLOR
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.FillTransparency = 0.5
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Enabled = ESP_ENABLED
        highlight.Parent = char

        highlights[player] = highlight
    end

    if player.Character then
        task.spawn(onCharacter, player.Character)
    end

    player.CharacterAdded:Connect(onCharacter)
end

for _,p in ipairs(Players:GetPlayers()) do
    createESP(p)
end
Players.PlayerAdded:Connect(createESP)

--================ TOGGLE ESP (G) =================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.G then
        ESP_ENABLED = not ESP_ENABLED
        for _,h in pairs(highlights) do
            if h then
                h.Enabled = ESP_ENABLED
            end
        end

        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "ESP Toggle",
                Text = ESP_ENABLED and "ESP: ON" or "ESP: OFF",
                Duration = 2
            })
        end)
    end
end)

end)
